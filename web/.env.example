# Optional: OpenAI for the Migration Assistant chat widget
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Required for production: secret used to sign session cookies (use a long random string)
# JWT_SECRET=

# API server port — must match vite proxy (vite.config reads this via loadEnv). Default in code is 5172 if unset.
# CHAT_API_PORT=5172

# When the Vite app is served from a different origin than the API, set the API base URL for the browser:
# VITE_CHAT_API_ORIGIN=http://127.0.0.1:5171
