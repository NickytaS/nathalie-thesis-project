# No leading spaces before KEY= — dotenv will not set OPENAI_API_KEY if the line starts with a space.
#
# Optional: GitHub repository root URL (no trailing slash) so Evidence links open files on the remote.
# Example: https://github.com/your-org/nathalie-thesis
# VITE_REPO_BASE_URL=

# --- OpenAI chat (server in web/server/chat-api.mjs; never commit real keys) ---
# OPENAI_API_KEY=sk-...
# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Port for the chat API (must match vite proxy; default 5171)
# CHAT_API_PORT=5171

# Local dev: leave VITE_CHAT_API_ORIGIN unset so the app calls /api on the same origin (Vite proxies to chat-api).
# Production (static site + API elsewhere): set to your API origin, e.g. https://api.example.com — no trailing slash.
# VITE_CHAT_API_ORIGIN=
